class Ejercicio12:

    @staticmethod
    def calcular_salario(horas_semana, valor_hora):
        por_retencion = 12.5 / 100

        salario_bruto = horas_semana * valor_hora
        retencion = int(salario_bruto * por_retencion)
        salario_neto = salario_bruto - retencion

        return salario_bruto, retencion, salario_neto

horas_semana = 48
valor_hora = 5000

salario_bruto, retencion, salario_neto = Ejercicio12.calcular_salario(horas_semana, valor_hora)

print(f"El salario bruto es: {salario_bruto}")
print(f"La retencion de la fuente es: {retencion}")
print(f"El salario neto es: {salario_neto}")
